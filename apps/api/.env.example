# Database (Supabase)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# App
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=troca_esse_secret_em_producao
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=troca_esse_refresh_secret_em_producao
JWT_REFRESH_EXPIRES_IN=30d

# Redis (Upstash)
REDIS_URL="rediss://:[token]@[host].upstash.io:6379"

# Mercado Pago
MP_ACCESS_TOKEN=seu_access_token_aqui
MP_WEBHOOK_SECRET=seu_webhook_secret_aqui

# Firebase (push notifications)
FIREBASE_PROJECT_ID=seu_project_id
FIREBASE_CLIENT_EMAIL=seu_client_email
FIREBASE_PRIVATE_KEY=sua_private_key

# Google Maps
GOOGLE_MAPS_API_KEY=sua_api_key_aqui

# Supabase Storage
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_KEY=sua_service_key_aqui

# Frete (configurável via admin)
DELIVERY_BASE_FEE=6.00
DELIVERY_FEE_PER_KM=1.50
