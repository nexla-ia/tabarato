generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ ENUMS ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

enum UserRole {
  CONSUMER
  STORE_OWNER
  COURIER
  ADMIN
}

enum StoreStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  WALLET
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DeliveryStatus {
  SEARCHING_COURIER
  COURIER_ASSIGNED
  COURIER_HEADING_TO_STORE
  COURIER_AT_STORE
  PICKED_UP
  HEADING_TO_CLIENT
  DELIVERED
  FAILED
}

enum CourierStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum WalletOwnerType {
  STORE
  COURIER
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum NotificationType {
  ORDER_UPDATE
  DELIVERY_UPDATE
  PAYMENT
  PROMOTION
  SYSTEM
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ USUГѓВЃRIOS ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String?
  passwordHash String   @map("password_hash")
  role         UserRole @default(CONSUMER)
  avatarUrl    String?  @map("avatar_url")
  city         String?
  state        String?
  isActive     Boolean  @default(true) @map("is_active")
  pushToken    String?  @map("push_token")
  referralCode String?  @unique @map("referral_code")
  referredBy   String?  @map("referred_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  addresses       Address[]
  orders          Order[]
  reviews         Review[]
  courierReviews  CourierReview[]
  notifications   Notification[]  @relation("RecipientNotifications")
  couponUses      CouponUse[]
  store           Store?
  courier         Courier?
  favorites       Favorite[]
  loyaltyAccount  LoyaltyAccount?
  chatMessages    ChatMessage[]

  @@map("users")
}

model Address {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  label      String
  street     String
  number     String
  complement String?
  district   String
  city       String
  state      String
  zipCode    String   @map("zip_code")
  lat        Float
  lng        Float
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ LOJAS ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  icon      String?
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  products Product[]
  stores   Store[]   @relation("StoresToCategories")

  @@map("categories")
}

model Store {
  id               String      @id @default(uuid())
  userId           String      @unique @map("user_id")
  cnpj             String      @unique
  name             String
  description      String?
  logoUrl          String?     @map("logo_url")
  phone            String?
  status           StoreStatus @default(PENDING)
  prepTimeMin      Int         @default(30) @map("prep_time_min")
  deliveryRadiusKm Float       @default(5.0) @map("delivery_radius_km")
  lat              Float
  lng              Float
  address          String
  pixKey           String?     @map("pix_key")
  photos           String[]    @default([])
  openingHours         Json?    @map("opening_hours")
  scheduleExceptions   Json?    @map("schedule_exceptions")
  isOpen               Boolean  @default(false) @map("is_open")
  maxConcurrentOrders  Int?     @map("max_concurrent_orders")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id])
  products   Product[]
  orders     Order[]
  categories Category[] @relation("StoresToCategories")
  reviews    Review[]
  coupons    Coupon[]
  favorites  Favorite[]

  @@map("stores")
}

// в”Ђв”Ђв”Ђ FIDELIDADE в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

model LoyaltyAccount {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  points         Int      @default(0)
  lifetimePoints Int      @default(0) @map("lifetime_points")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]

  @@map("loyalty_accounts")
}

model LoyaltyTransaction {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  points      Int
  type        String   // EARN | REDEEM | BONUS
  description String?
  orderId     String?  @map("order_id")
  createdAt   DateTime @default(now()) @map("created_at")

  account LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("loyalty_transactions")
}

// в”Ђв”Ђв”Ђ CHAT в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

model ChatMessage {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  senderId   String   @map("sender_id")
  senderRole String   @map("sender_role")
  content    String
  createdAt  DateTime @default(now()) @map("created_at")

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender User  @relation(fields: [senderId], references: [id])

  @@index([orderId])
  @@map("chat_messages")
}

// в”Ђв”Ђв”Ђ FAVORITOS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

model Favorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  storeId   String   @map("store_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([userId])
  @@map("favorites")
}

model Product {
  id            String   @id @default(uuid())
  storeId       String   @map("store_id")
  categoryId    String   @map("category_id")
  name          String
  description   String?
  imageUrl      String?  @map("image_url")
  hasVariations  Boolean  @default(false) @map("has_variations")
  basePrice      Decimal? @map("base_price")
  maxDeliveryKm  Float?   @map("max_delivery_km")
  stock         Int?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  store      Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category   Category           @relation(fields: [categoryId], references: [id])
  variations ProductVariation[]
  orderItems OrderItem[]

  @@index([storeId])
  @@map("products")
}

model ProductVariation {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  sku       String?
  name      String
  size      String?
  color     String?
  price     Decimal
  stock     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@map("product_variations")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ PEDIDOS ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Order {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  storeId     String      @map("store_id")
  addressId   String      @map("address_id")
  paymentId   String?     @map("payment_id")
  subtotal    Decimal
  deliveryFee Decimal     @map("delivery_fee")
  discount    Decimal     @default(0)
  total       Decimal
  couponId    String?     @map("coupon_id")
  status      OrderStatus @default(PENDING)
  notes       String?
  refusalNote String?     @map("refusal_note")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id])
  store         Store          @relation(fields: [storeId], references: [id])
  address       Address        @relation(fields: [addressId], references: [id])
  payment       Payment?       @relation(fields: [paymentId], references: [id])
  coupon        Coupon?        @relation(fields: [couponId], references: [id])
  items         OrderItem[]
  delivery      Delivery?
  review        Review?
  courierReview CourierReview?
  couponUse     CouponUse?
  statusHistory OrderStatusHistory[]
  chatMessages  ChatMessage[]

  @@index([userId])
  @@index([storeId])
  @@index([status])
  @@index([status, createdAt])
  @@map("orders")
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String      @map("order_id")
  status    OrderStatus
  changedBy String?     @map("changed_by")
  note      String?
  createdAt DateTime    @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  productId   String  @map("product_id")
  variationId String? @map("variation_id")
  quantity    Int
  unitPrice   Decimal @map("unit_price")
  notes       String?

  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product           @relation(fields: [productId], references: [id])
  variation ProductVariation? @relation(fields: [variationId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model Payment {
  id             String        @id @default(uuid())
  method         PaymentMethod
  gatewayId      String?       @map("gateway_id")
  idempotencyKey String?       @unique @map("idempotency_key")
  status         PaymentStatus @default(PENDING)
  amount         Decimal
  pixCode        String?       @map("pix_code")
  pixQrBase64    String?       @map("pix_qr_base64")
  pixExpiresAt   DateTime?     @map("pix_expires_at")
  paidAt         DateTime?     @map("paid_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  orders Order[]

  @@index([gatewayId])
  @@index([status])
  @@map("payments")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ LOGГѓВЌSTICA ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Courier {
  id                 String        @id @default(uuid())
  userId             String        @unique @map("user_id")
  cpf                String        @unique
  cnh                String        @unique
  vehiclePlate       String        @map("vehicle_plate")
  vehicleType        String        @default("moto") @map("vehicle_type")
  photoUrl           String?       @map("photo_url")
  cnhPhotoUrl        String?       @map("cnh_photo_url")
  identityPhotoUrl   String?       @map("identity_photo_url")
  vehicleDocPhotoUrl String?       @map("vehicle_doc_photo_url")
  cnhStatus          String?       @map("cnh_status")
  identityStatus     String?       @map("identity_status")
  vehicleDocStatus   String?       @map("vehicle_doc_status")
  status             CourierStatus @default(PENDING)
  isOnline           Boolean       @default(false) @map("is_online")
  currentLat         Float?        @map("current_lat")
  currentLng         Float?        @map("current_lng")
  rating             Float         @default(5.0)
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id])
  deliveries     Delivery[]
  courierReviews CourierReview[]

  @@map("couriers")
}

model Delivery {
  id          String         @id @default(uuid())
  orderId     String         @unique @map("order_id")
  courierId   String?        @map("courier_id")
  distanceKm  Decimal        @map("distance_km")
  courierFee  Decimal        @map("courier_fee")
  status      DeliveryStatus @default(SEARCHING_COURIER)
  photoUrl    String?        @map("photo_url")
  pickedUpAt  DateTime?      @map("picked_up_at")
  deliveredAt DateTime?      @map("delivered_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  order   Order    @relation(fields: [orderId], references: [id])
  courier Courier? @relation(fields: [courierId], references: [id])

  @@index([courierId])
  @@index([status])
  @@map("deliveries")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ FINANCEIRO ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Wallet {
  id        String          @id @default(uuid())
  ownerId   String          @map("owner_id")
  ownerType WalletOwnerType @map("owner_type")
  balance   Decimal         @default(0)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  transactions Transaction[]

  @@unique([ownerId, ownerType])
  @@map("wallets")
}

model Transaction {
  id          String          @id @default(uuid())
  walletId    String          @map("wallet_id")
  amount      Decimal
  type        TransactionType
  description String?
  referenceId String?         @map("reference_id")
  createdAt   DateTime        @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@map("transactions")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ ENGAJAMENTO ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  storeId   String   @map("store_id")
  orderId   String   @unique @map("order_id")
  rating    Int
  comment   String?
  photos    String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])
  order Order @relation(fields: [orderId], references: [id])

  @@index([storeId, createdAt])
  @@map("reviews")
}

model CourierReview {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  courierId String   @map("courier_id")
  orderId   String   @unique @map("order_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  courier Courier @relation(fields: [courierId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])

  @@index([courierId])
  @@map("courier_reviews")
}

model Notification {
  id          String           @id @default(uuid())
  recipientId String           @map("recipient_id")
  type        NotificationType
  title       String
  body        String?
  data        Json?
  isRead      Boolean          @default(false) @map("is_read")
  createdAt   DateTime         @default(now()) @map("created_at")

  recipient User @relation("RecipientNotifications", fields: [recipientId], references: [id])

  @@index([recipientId, isRead])
  @@index([recipientId, createdAt])
  @@map("notifications")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ PROMOГѓвЂЎГѓвЂўES ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Coupon {
  id              String    @id @default(uuid())
  storeId         String?   @map("store_id")
  code            String    @unique
  description     String?
  discountPercent Decimal?  @map("discount_percent")
  discountFixed   Decimal?  @map("discount_fixed")
  minOrderValue   Decimal?  @map("min_order_value")
  maxUses         Int?      @map("max_uses")
  usedCount       Int       @default(0) @map("used_count")
  expiresAt       DateTime? @map("expires_at")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")

  store  Store?      @relation(fields: [storeId], references: [id])
  uses   CouponUse[]
  orders Order[]

  @@index([expiresAt])
  @@map("coupons")
}

model CouponUse {
  id       String   @id @default(uuid())
  couponId String   @map("coupon_id")
  userId   String   @map("user_id")
  orderId  String   @unique @map("order_id")
  usedAt   DateTime @default(now()) @map("used_at")

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])

  @@unique([couponId, userId])
  @@map("coupon_uses")
}
